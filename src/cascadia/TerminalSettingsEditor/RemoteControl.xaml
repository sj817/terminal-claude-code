<Page x:Class="Microsoft.Terminal.Settings.Editor.RemoteControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:Microsoft.Terminal.Settings.Editor"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CommonResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <StackPanel Style="{StaticResource SettingsStackStyle}">
        <!-- Security notice: the API is localhost-only and disabled by default. -->
        <muxc:InfoBar x:Name="RemoteControlSecurityNotice"
                      x:Uid="Globals_RemoteControlSecurityNotice"
                      IsClosable="False"
                      IsOpen="True"
                      Severity="Warning" />

        <local:SettingContainer x:Name="RemoteControlEnabled"
                                x:Uid="Globals_RemoteControlEnabled">
            <ToggleSwitch IsOn="{x:Bind ViewModel.RemoteControlEnabled, Mode=TwoWay}"
                          Style="{StaticResource ToggleSwitchInExpanderStyle}" />
        </local:SettingContainer>

        <!-- Host is loopback-only; shown read-only. -->
        <local:SettingContainer x:Name="RemoteControlHost"
                                x:Uid="Globals_RemoteControlHost"
                                CurrentValue="{x:Bind ViewModel.RemoteControlHost, Mode=OneWay}"
                                Style="{StaticResource ExpanderSettingContainerStyle}">
            <TextBox IsEnabled="False"
                     IsSpellCheckEnabled="False"
                     Style="{StaticResource TextBoxSettingStyle}"
                     Text="{x:Bind ViewModel.RemoteControlHost, Mode=OneWay}" />
        </local:SettingContainer>

        <local:SettingContainer x:Name="RemoteControlPort"
                                x:Uid="Globals_RemoteControlPort">
            <muxc:NumberBox Maximum="65535"
                            Minimum="1"
                            SpinButtonPlacementMode="Inline"
                            Style="{StaticResource NumberBoxSettingStyle}"
                            Value="{x:Bind ViewModel.RemoteControlPort, Mode=TwoWay}" />
        </local:SettingContainer>

        <local:SettingContainer x:Name="RemoteControlToken"
                                x:Uid="Globals_RemoteControlToken"
                                Style="{StaticResource ExpanderSettingContainerStyle}">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <TextBox MinWidth="280"
                         IsSpellCheckEnabled="False"
                         Style="{StaticResource TextBoxSettingStyle}"
                         Text="{x:Bind ViewModel.TokenInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button x:Uid="Globals_RemoteControlApplyToken"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="ApplyToken_Click" />
            </StackPanel>
        </local:SettingContainer>

        <local:SettingContainer x:Name="AllowRemoteInput"
                                x:Uid="Globals_AllowRemoteInput">
            <ToggleSwitch IsOn="{x:Bind ViewModel.AllowRemoteInput, Mode=TwoWay}"
                          Style="{StaticResource ToggleSwitchInExpanderStyle}" />
        </local:SettingContainer>

        <local:SettingContainer x:Name="AllowRemoteSnapshot"
                                x:Uid="Globals_AllowRemoteSnapshot">
            <ToggleSwitch IsOn="{x:Bind ViewModel.AllowRemoteSnapshot, Mode=TwoWay}"
                          Style="{StaticResource ToggleSwitchInExpanderStyle}" />
        </local:SettingContainer>

        <local:SettingContainer x:Name="AllowRemoteWebSocket"
                                x:Uid="Globals_AllowRemoteWebSocket">
            <ToggleSwitch IsOn="{x:Bind ViewModel.AllowRemoteWebSocket, Mode=TwoWay}"
                          Style="{StaticResource ToggleSwitchInExpanderStyle}" />
        </local:SettingContainer>
    </StackPanel>
</Page>
